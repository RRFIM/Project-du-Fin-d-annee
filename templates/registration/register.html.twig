{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}

{{ form_errors(registrationForm) }}

{{ form_start(registrationForm) }}
    <section>
        <header class="flex flex-col bg-[#078ADB] text-white rounded-b-lg h-34">
            <div class="flex items-center">
                <img src="{{asset("/icons/Header/Vector.svg")}}" class="py-3 px-3">
                <h1 class="text-[32px]">FanGame Archive</h1>
            </div>

            <h2 class="px-27 text-[24px]">always expanding and changing</h2>
        </header>
        
        <div class="flex flex-col gap-y-5 px-20 py-4 w-92">

                <div class="flex items-center px-5.5 py-3 justify-between rounded-3xl bg-[#d9d9d9]">
                    <a href="{{path("app_login")}}">    
                        <button>Login</button>
                    </a>
                    
                    <a href="{{path("app_register")}}" class="rounded-2xl bg-[#A1A1A1] px-6 py-3">
                        <button>Register</button>
                    </a>
                </div>
                
                <div class="flex flex-col gap-y-2">

                    <div class="flex flex-col gap-y-2">
                        {{ form_label(registrationForm.username) }}
                        <div>
                        {{ form_widget(registrationForm.username, {attr:{placeholder:"Username", class:"bg-[#D9D9D9] border border-solid border-black px-4 py-1 rounded-tr-lg"}}) }}
                        </div>
                    </div>
                        
                    <div class="flex flex-col gap-y-2">
                        {{ form_label(registrationForm.email) }}
                        <div>
                            {{ form_widget(registrationForm.email, {attr:{placeholder:"your@email.com", class:"bg-[#D9D9D9] border border-solid border-black px-4 py-1 rounded-tr-lg"}}) }}
                        </div>
                    </div>
                
                    <div class="flex flex-col gap-y-2">
                        {{ form_label(registrationForm.plainPassword) }}
                        <div>
                            {{ form_widget(registrationForm.plainPassword, {attr:{placeholder:"••••••••", class:"bg-[#D9D9D9] border border-solid border-black px-4 py-1 rounded-tr-lg"}}) }}
                        </div>
                    </div>
                    

                    {{ form_widget(registrationForm.status, {attr:{class:"bg-[#D9D9D9] px-3 w-16 size-10 rounded-2xl"}}) }}
                
                <div>
                    {{ form_widget(registrationForm.agreeTerms) }}
                    {{ form_label(registrationForm.agreeTerms) }}
                </div>
                
                <button type="submit" class="flex bg-black text-white h-12 w-64 rounded-xl justify-center items-center" >Register</button>
            </div>
        </div>
    </section>
    {{ form_end(registrationForm) }}
{% endblock %}
